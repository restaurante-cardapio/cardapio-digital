{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "firestore.indexes.json",
      ".gitignore",
      "README.md",
      "LICENSE",
      "LICENSE.md",
      "node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin-produtos.html"
      },
      {
        "source": "/termos",
        "destination": "/termos.html"
      },
      {
        "source": "/privacidade",
        "destination": "/privacidade.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=604800"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
